# Auto detect text files and normalize line endings to LF
* text=auto

# Explicitly declare text files
*.css text
*.html text
*.js text
*.json text
*.jsx text
*.md text
*.mjs text
*.ts text
*.tsx text
*.xml text
*.yml text

# Declare files that will always have CRLF line endings on checkout
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
